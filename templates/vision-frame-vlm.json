{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "Blacknode Vision Frame VLM",
  "saved_at": "2026-07-10T00:00:00",
  "entrypoint": {
    "node_id": "vlm_out",
    "port": "value"
  },
  "metadata": {
    "template": true,
    "description": "Capture one ROS 2 camera frame, show it on the canvas, and send the frame to an OpenAI-compatible VLM endpoint for visual reasoning.",
    "color": "#18a058",
    "required_packages": [
      {"name": "blacknode-perception", "git_url": "https://github.com/temiroff/blacknode-perception.git", "node_types": ["VisionFramePrompt", "VisionVLMDescribe"]},
      "blacknode-ros2"
    ]
  },
  "node_meta": {
    "check": {
      "id": "check",
      "type": "ROS2SystemCheck",
      "params": {"refresh": true},
      "pos": [40, 180],
      "inputs": ["refresh"],
      "outputs": ["available", "backend", "report"],
      "input_types": {"refresh": "Bool"},
      "output_types": {"available": "Bool", "backend": "Text", "report": "Text"},
      "input_defaults": {"refresh": true}
    },
    "snapshot": {
      "id": "snapshot",
      "type": "ROS2ImageSnapshot",
      "params": {
        "topic": "/camera/image_raw",
        "timeout": 10.0,
        "output_format": "jpeg",
        "jpeg_quality": 85
      },
      "pos": [390, 220],
      "inputs": ["trigger", "topic", "timeout", "output_format", "jpeg_quality"],
      "outputs": ["image", "metadata", "report"],
      "input_types": {
        "trigger": "Any",
        "topic": "Text",
        "timeout": "Float",
        "output_format": "Text",
        "jpeg_quality": "Int"
      },
      "output_types": {"image": "Image", "metadata": "Dict", "report": "Text"},
      "input_defaults": {
        "topic": "/camera/image_raw",
        "timeout": 10.0,
        "output_format": "jpeg",
        "jpeg_quality": 85
      },
      "input_choices": {"output_format": ["png", "jpeg"]}
    },
    "prompt": {
      "id": "prompt",
      "type": "VisionFramePrompt",
      "params": {
        "question": "What does the robot camera see, and what should the robot do next?",
        "context": "Live robot camera frame",
        "robot_task": "understand the workspace",
        "include_safety_checks": true
      },
      "pos": [760, 70],
      "inputs": ["image", "question", "context", "robot_task", "include_safety_checks"],
      "outputs": ["prompt", "summary"],
      "input_types": {
        "image": "Image",
        "question": "Text",
        "context": "Text",
        "robot_task": "Text",
        "include_safety_checks": "Bool"
      },
      "output_types": {"prompt": "Text", "summary": "Dict"},
      "input_defaults": {
        "question": "What does the robot camera see, and what should the robot do next?",
        "context": "Live robot camera frame",
        "robot_task": "understand the workspace",
        "include_safety_checks": true
      }
    },
    "vlm": {
      "id": "vlm",
      "type": "VisionVLMDescribe",
      "params": {
        "provider": "openai-compatible",
        "model": "gpt-4o-mini",
        "endpoint_url": "https://api.openai.com/v1",
        "api_key": "",
        "max_tokens": 512,
        "temperature": 0.2,
        "allow_text_only": false
      },
      "pos": [1120, 180],
      "inputs": ["image", "question", "system", "provider", "model", "endpoint_url", "api_key", "max_tokens", "temperature", "allow_text_only"],
      "outputs": ["text", "report", "raw"],
      "input_types": {
        "image": "Image",
        "question": "Text",
        "system": "Text",
        "provider": "Text",
        "model": "Text",
        "endpoint_url": "Text",
        "api_key": "Text",
        "max_tokens": "Int",
        "temperature": "Float",
        "allow_text_only": "Bool"
      },
      "output_types": {"text": "Text", "report": "Text", "raw": "Dict"},
      "input_defaults": {
        "question": "What do you see?",
        "system": "You are a precise robot vision assistant. Describe only what is visible.",
        "provider": "openai-compatible",
        "model": "gpt-4o-mini",
        "endpoint_url": "https://api.openai.com/v1",
        "api_key": "",
        "max_tokens": 512,
        "temperature": 0.2,
        "allow_text_only": false
      },
      "input_choices": {"provider": ["openai-compatible", "anthropic", "ollama", "auto"]}
    },
    "image_out": {
      "id": "image_out",
      "type": "OutputImage",
      "params": {},
      "pos": [760, 390],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": {"image": "Image"},
      "output_types": {"image": "Image"},
      "input_defaults": {}
    },
    "vlm_out": {
      "id": "vlm_out",
      "type": "Output",
      "params": {"label": "VLM answer"},
      "pos": [1480, 180],
      "inputs": ["value"],
      "outputs": [],
      "input_types": {"value": "Any"},
      "output_types": {},
      "input_defaults": {}
    },
    "report_out": {
      "id": "report_out",
      "type": "Output",
      "params": {"label": "Vision report"},
      "pos": [1480, 390],
      "inputs": ["value"],
      "outputs": [],
      "input_types": {"value": "Any"},
      "output_types": {},
      "input_defaults": {}
    }
  },
  "edges": [
    {"from": "check", "from_port": "report", "to": "snapshot", "to_port": "trigger"},
    {"from": "snapshot", "from_port": "image", "to": "prompt", "to_port": "image"},
    {"from": "snapshot", "from_port": "image", "to": "vlm", "to_port": "image"},
    {"from": "snapshot", "from_port": "image", "to": "image_out", "to_port": "image"},
    {"from": "prompt", "from_port": "prompt", "to": "vlm", "to_port": "question"},
    {"from": "vlm", "from_port": "text", "to": "vlm_out", "to_port": "value"},
    {"from": "vlm", "from_port": "report", "to": "report_out", "to_port": "value"}
  ]
}
