{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "Blacknode Vision Camera Console",
  "saved_at": "2026-07-10T00:00:00",
  "entrypoint": {
    "node_id": "image_out",
    "port": "image"
  },
  "metadata": {
    "template": true,
    "description": "Start the bundled Blacknode USB camera ROS 2 node, stream its image topic, and show a live vision status dashboard.",
    "color": "#18a058",
    "required_packages": [
      {"name": "blacknode-vision", "git_url": "https://github.com/temiroff/blacknode-vision.git", "node_types": ["VisionStreamStatus"]},
      "blacknode-ros2"
    ]
  },
  "node_meta": {
    "check": {
      "id": "check",
      "type": "ROS2SystemCheck",
      "params": {"refresh": true},
      "pos": [40, 180],
      "inputs": ["refresh"],
      "outputs": ["available", "backend", "report"],
      "input_types": {"refresh": "Bool"},
      "output_types": {"available": "Bool", "backend": "Text", "report": "Text"},
      "input_defaults": {"refresh": true}
    },
    "camera_run": {
      "id": "camera_run",
      "type": "ROS2Run",
      "params": {
        "action": "start",
        "run_id": "vision_camera",
        "package": "blacknode_usb_camera",
        "executable": "usb_camera",
        "arguments": "--ros-args -p device:=0 -p image_topic:=/camera/image_raw -p width:=640 -p height:=480 -p hz:=30.0",
        "expected_topic": "/camera/image_raw",
        "wait_seconds": 10.0
      },
      "pos": [390, 160],
      "inputs": ["trigger", "action", "run_id", "package", "executable", "arguments", "expected_topic", "wait_seconds"],
      "outputs": ["running", "run_id", "report"],
      "input_types": {
        "trigger": "Any",
        "action": "Text",
        "run_id": "Text",
        "package": "Text",
        "executable": "Text",
        "arguments": "Text",
        "expected_topic": "Text",
        "wait_seconds": "Float"
      },
      "output_types": {"running": "Bool", "run_id": "Text", "report": "Text"},
      "input_defaults": {
        "action": "start",
        "run_id": "vision_camera",
        "package": "blacknode_usb_camera",
        "executable": "usb_camera",
        "arguments": "--ros-args -p device:=0 -p image_topic:=/camera/image_raw -p width:=640 -p height:=480 -p hz:=30.0",
        "expected_topic": "/camera/image_raw",
        "wait_seconds": 10.0
      },
      "input_choices": {"action": ["start", "stop"]}
    },
    "stream": {
      "id": "stream",
      "type": "ROS2ImageStream",
      "params": {
        "action": "start",
        "stream_id": "vision_camera",
        "topic": "/camera/image_raw",
        "message_type": "auto",
        "host": "127.0.0.1",
        "port": 0,
        "max_fps": 10.0,
        "max_width": 960,
        "jpeg_quality": 80
      },
      "pos": [740, 240],
      "inputs": ["trigger", "action", "stream_id", "topic", "message_type", "host", "port", "max_fps", "max_width", "jpeg_quality"],
      "outputs": ["preview", "streaming", "stream_url", "snapshot_url", "stream_id", "report"],
      "input_types": {
        "trigger": "Any",
        "action": "Text",
        "stream_id": "Text",
        "topic": "Text",
        "message_type": "Text",
        "host": "Text",
        "port": "Int",
        "max_fps": "Float",
        "max_width": "Int",
        "jpeg_quality": "Int"
      },
      "output_types": {
        "preview": "Image",
        "streaming": "Bool",
        "stream_url": "Text",
        "snapshot_url": "Text",
        "stream_id": "Text",
        "report": "Text"
      },
      "input_defaults": {
        "action": "start",
        "stream_id": "vision_camera",
        "topic": "/camera/image_raw",
        "message_type": "auto",
        "host": "127.0.0.1",
        "port": 0,
        "max_fps": 10.0,
        "max_width": 960,
        "jpeg_quality": 80
      },
      "input_choices": {
        "action": ["start", "stop"],
        "message_type": ["auto", "raw", "compressed"]
      }
    },
    "status": {
      "id": "status",
      "type": "VisionStreamStatus",
      "params": {"camera_topic": "/camera/image_raw"},
      "pos": [1120, 40],
      "inputs": ["camera_topic", "stream_url", "streaming", "run_report", "stream_report"],
      "outputs": ["dashboard", "ready", "report"],
      "input_types": {
        "camera_topic": "Text",
        "stream_url": "Text",
        "streaming": "Bool",
        "run_report": "Text",
        "stream_report": "Text"
      },
      "output_types": {"dashboard": "Image", "ready": "Bool", "report": "Text"},
      "input_defaults": {"camera_topic": "/camera/image_raw"}
    },
    "image_out": {
      "id": "image_out",
      "type": "OutputImage",
      "params": {},
      "pos": [1120, 360],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": {"image": "Image"},
      "output_types": {"image": "Image"},
      "input_defaults": {}
    },
    "status_out": {
      "id": "status_out",
      "type": "OutputImage",
      "params": {},
      "pos": [1500, 40],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": {"image": "Image"},
      "output_types": {"image": "Image"},
      "input_defaults": {}
    },
    "report_out": {
      "id": "report_out",
      "type": "Output",
      "params": {"label": "Vision camera report"},
      "pos": [1500, 360],
      "inputs": ["value"],
      "outputs": [],
      "input_types": {"value": "Any"},
      "output_types": {},
      "input_defaults": {}
    }
  },
  "edges": [
    {"from": "check", "from_port": "report", "to": "camera_run", "to_port": "trigger"},
    {"from": "camera_run", "from_port": "report", "to": "stream", "to_port": "trigger"},
    {"from": "camera_run", "from_port": "report", "to": "status", "to_port": "run_report"},
    {"from": "stream", "from_port": "preview", "to": "image_out", "to_port": "image"},
    {"from": "stream", "from_port": "stream_url", "to": "status", "to_port": "stream_url"},
    {"from": "stream", "from_port": "streaming", "to": "status", "to_port": "streaming"},
    {"from": "stream", "from_port": "report", "to": "status", "to_port": "stream_report"},
    {"from": "status", "from_port": "dashboard", "to": "status_out", "to_port": "image"},
    {"from": "status", "from_port": "report", "to": "report_out", "to_port": "value"}
  ]
}
