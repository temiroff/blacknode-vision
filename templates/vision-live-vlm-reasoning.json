{
  "kind": "blacknode.workflow",
  "schema_version": 1,
  "name": "Blacknode Vision Live VLM Reasoning",
  "saved_at": "2026-07-10T00:00:00",
  "entrypoint": {
    "node_id": "reasoning_out",
    "port": "image"
  },
  "metadata": {
    "template": true,
    "description": "Start the bundled USB camera, show a live stream, capture one frame, send it to a VLM, and render visible observations/evidence/action on a dashboard.",
    "color": "#18a058",
    "required_packages": [
      {
        "name": "blacknode-perception",
        "git_url": "https://github.com/temiroff/blacknode-perception.git",
        "node_types": ["FramePrompt", "VLMDescribe", "ReasoningDashboard", "StreamStatus"]
      },
      "blacknode-ros2"
    ]
  },
  "node_meta": {
    "check": {
      "id": "check",
      "type": "ROS2SystemCheck",
      "params": {"refresh": true},
      "pos": [40, 170],
      "inputs": ["refresh"],
      "outputs": ["available", "backend", "report"],
      "input_types": {"refresh": "Bool"},
      "output_types": {"available": "Bool", "backend": "Text", "report": "Text"},
      "input_defaults": {"refresh": true}
    },
    "camera_run": {
      "id": "camera_run",
      "type": "ROS2Run",
      "params": {
        "action": "start",
        "run_id": "vision_camera",
        "package": "blacknode_usb_camera",
        "executable": "usb_camera",
        "arguments": "--ros-args -p device:=0 -p image_topic:=/camera/image_raw -p width:=640 -p height:=480 -p hz:=30.0",
        "expected_topic": "/camera/image_raw",
        "wait_seconds": 10.0
      },
      "pos": [390, 120],
      "inputs": ["trigger", "action", "run_id", "package", "executable", "arguments", "expected_topic", "wait_seconds"],
      "outputs": ["running", "run_id", "report"],
      "input_types": {
        "trigger": "Any",
        "action": "Text",
        "run_id": "Text",
        "package": "Text",
        "executable": "Text",
        "arguments": "Text",
        "expected_topic": "Text",
        "wait_seconds": "Float"
      },
      "output_types": {"running": "Bool", "run_id": "Text", "report": "Text"},
      "input_defaults": {
        "action": "start",
        "run_id": "vision_camera",
        "package": "blacknode_usb_camera",
        "executable": "usb_camera",
        "arguments": "--ros-args -p device:=0 -p image_topic:=/camera/image_raw -p width:=640 -p height:=480 -p hz:=30.0",
        "expected_topic": "/camera/image_raw",
        "wait_seconds": 10.0
      },
      "input_choices": {"action": ["start", "stop"]}
    },
    "stream": {
      "id": "stream",
      "type": "ROS2ImageStream",
      "params": {
        "action": "start",
        "stream_id": "vision_camera",
        "topic": "/camera/image_raw",
        "message_type": "auto",
        "host": "127.0.0.1",
        "port": 0,
        "max_fps": 10.0,
        "max_width": 960,
        "jpeg_quality": 80
      },
      "pos": [740, 80],
      "inputs": ["trigger", "action", "stream_id", "topic", "message_type", "host", "port", "max_fps", "max_width", "jpeg_quality"],
      "outputs": ["preview", "streaming", "stream_url", "snapshot_url", "stream_id", "report"],
      "input_types": {
        "trigger": "Any",
        "action": "Text",
        "stream_id": "Text",
        "topic": "Text",
        "message_type": "Text",
        "host": "Text",
        "port": "Int",
        "max_fps": "Float",
        "max_width": "Int",
        "jpeg_quality": "Int"
      },
      "output_types": {
        "preview": "Image",
        "streaming": "Bool",
        "stream_url": "Text",
        "snapshot_url": "Text",
        "stream_id": "Text",
        "report": "Text"
      },
      "input_defaults": {
        "action": "start",
        "stream_id": "vision_camera",
        "topic": "/camera/image_raw",
        "message_type": "auto",
        "host": "127.0.0.1",
        "port": 0,
        "max_fps": 10.0,
        "max_width": 960,
        "jpeg_quality": 80
      },
      "input_choices": {
        "action": ["start", "stop"],
        "message_type": ["auto", "raw", "compressed"]
      }
    },
    "snapshot": {
      "id": "snapshot",
      "type": "ROS2ImageSnapshot",
      "params": {
        "topic": "/camera/image_raw",
        "timeout": 10.0,
        "output_format": "jpeg",
        "jpeg_quality": 82
      },
      "pos": [740, 380],
      "inputs": ["trigger", "topic", "timeout", "output_format", "jpeg_quality"],
      "outputs": ["image", "metadata", "report"],
      "input_types": {
        "trigger": "Any",
        "topic": "Text",
        "timeout": "Float",
        "output_format": "Text",
        "jpeg_quality": "Int"
      },
      "output_types": {"image": "Image", "metadata": "Dict", "report": "Text"},
      "input_defaults": {
        "topic": "/camera/image_raw",
        "timeout": 10.0,
        "output_format": "jpeg",
        "jpeg_quality": 82
      },
      "input_choices": {"output_format": ["png", "jpeg"]}
    },
    "prompt": {
      "id": "prompt",
      "type": "FramePrompt",
      "params": {
        "question": "Describe what the robot sees. Include visible evidence, uncertainty, safety concerns, and the next useful robot action.",
        "context": "Live Blacknode USB camera frame",
        "robot_task": "understand the workspace before acting",
        "include_safety_checks": true
      },
      "pos": [1120, 360],
      "inputs": ["image", "question", "context", "robot_task", "include_safety_checks"],
      "outputs": ["prompt", "summary"],
      "input_types": {
        "image": "Image",
        "question": "Text",
        "context": "Text",
        "robot_task": "Text",
        "include_safety_checks": "Bool"
      },
      "output_types": {"prompt": "Text", "summary": "Dict"},
      "input_defaults": {
        "question": "Describe what the robot sees. Include visible evidence, uncertainty, safety concerns, and the next useful robot action.",
        "context": "Live Blacknode USB camera frame",
        "robot_task": "understand the workspace before acting",
        "include_safety_checks": true
      }
    },
    "vlm": {
      "id": "vlm",
      "type": "VLMDescribe",
      "params": {
        "provider": "openai-compatible",
        "model": "gpt-4o-mini",
        "endpoint_url": "https://api.openai.com/v1",
        "api_key": "",
        "max_tokens": 700,
        "temperature": 0.2,
        "allow_text_only": false
      },
      "pos": [1490, 360],
      "inputs": ["image", "question", "system", "provider", "model", "endpoint_url", "api_key", "max_tokens", "temperature", "allow_text_only"],
      "outputs": ["text", "report", "raw"],
      "input_types": {
        "image": "Image",
        "question": "Text",
        "system": "Text",
        "provider": "Text",
        "model": "Text",
        "endpoint_url": "Text",
        "api_key": "Text",
        "max_tokens": "Int",
        "temperature": "Float",
        "allow_text_only": "Bool"
      },
      "output_types": {"text": "Text", "report": "Text", "raw": "Dict"},
      "input_defaults": {
        "question": "What do you see?",
        "system": "You are a precise robot vision assistant. Do not invent details. Return visible observations, supporting evidence, uncertainty, safety notes, and one next action.",
        "provider": "openai-compatible",
        "model": "gpt-4o-mini",
        "endpoint_url": "https://api.openai.com/v1",
        "api_key": "",
        "max_tokens": 700,
        "temperature": 0.2,
        "allow_text_only": false
      },
      "input_choices": {"provider": ["openai-compatible", "anthropic", "ollama", "auto"]}
    },
    "reasoning": {
      "id": "reasoning",
      "type": "ReasoningDashboard",
      "params": {"title": "Blacknode Vision Reasoning"},
      "pos": [1880, 250],
      "inputs": ["image", "answer", "prompt", "report", "title"],
      "outputs": ["dashboard", "ready", "summary"],
      "input_types": {
        "image": "Image",
        "answer": "Text",
        "prompt": "Text",
        "report": "Text",
        "title": "Text"
      },
      "output_types": {"dashboard": "Image", "ready": "Bool", "summary": "Dict"},
      "input_defaults": {"title": "Blacknode Vision Reasoning"}
    },
    "stream_out": {
      "id": "stream_out",
      "type": "OutputImage",
      "params": {},
      "pos": [1120, 40],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": {"image": "Image"},
      "output_types": {"image": "Image"},
      "input_defaults": {}
    },
    "snapshot_out": {
      "id": "snapshot_out",
      "type": "OutputImage",
      "params": {},
      "pos": [1120, 650],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": {"image": "Image"},
      "output_types": {"image": "Image"},
      "input_defaults": {}
    },
    "reasoning_out": {
      "id": "reasoning_out",
      "type": "OutputImage",
      "params": {},
      "pos": [2280, 250],
      "inputs": ["image"],
      "outputs": ["image"],
      "input_types": {"image": "Image"},
      "output_types": {"image": "Image"},
      "input_defaults": {}
    },
    "answer_out": {
      "id": "answer_out",
      "type": "Output",
      "params": {"label": "VLM visible reasoning"},
      "pos": [2280, 620],
      "inputs": ["value"],
      "outputs": [],
      "input_types": {"value": "Any"},
      "output_types": {},
      "input_defaults": {}
    },
    "report_out": {
      "id": "report_out",
      "type": "Output",
      "params": {"label": "VLM report"},
      "pos": [2280, 820],
      "inputs": ["value"],
      "outputs": [],
      "input_types": {"value": "Any"},
      "output_types": {},
      "input_defaults": {}
    }
  },
  "edges": [
    {"from": "check", "from_port": "report", "to": "camera_run", "to_port": "trigger"},
    {"from": "camera_run", "from_port": "report", "to": "stream", "to_port": "trigger"},
    {"from": "camera_run", "from_port": "report", "to": "snapshot", "to_port": "trigger"},
    {"from": "stream", "from_port": "preview", "to": "stream_out", "to_port": "image"},
    {"from": "snapshot", "from_port": "image", "to": "prompt", "to_port": "image"},
    {"from": "snapshot", "from_port": "image", "to": "vlm", "to_port": "image"},
    {"from": "snapshot", "from_port": "image", "to": "snapshot_out", "to_port": "image"},
    {"from": "snapshot", "from_port": "image", "to": "reasoning", "to_port": "image"},
    {"from": "prompt", "from_port": "prompt", "to": "vlm", "to_port": "question"},
    {"from": "prompt", "from_port": "prompt", "to": "reasoning", "to_port": "prompt"},
    {"from": "vlm", "from_port": "text", "to": "reasoning", "to_port": "answer"},
    {"from": "vlm", "from_port": "text", "to": "answer_out", "to_port": "value"},
    {"from": "vlm", "from_port": "report", "to": "reasoning", "to_port": "report"},
    {"from": "vlm", "from_port": "report", "to": "report_out", "to_port": "value"},
    {"from": "reasoning", "from_port": "dashboard", "to": "reasoning_out", "to_port": "image"}
  ]
}
